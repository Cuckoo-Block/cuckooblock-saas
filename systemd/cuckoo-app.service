[Unit]
Description=Cuckoo App Next.js service
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/admin/cuckoo-app
ExecStartPre=/usr/bin/npm run build
ExecStart=/usr/bin/npm run start:startup
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
